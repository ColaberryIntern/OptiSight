# PostgreSQL
POSTGRES_USER=retail_insight
POSTGRES_PASSWORD=changeme
POSTGRES_DB=retail_insight
DATABASE_URL=postgres://retail_insight:changeme@postgres:5432/retail_insight

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=24h

# bcrypt
BCRYPT_SALT_ROUNDS=10

# Service Ports
USER_SERVICE_PORT=3001
DATA_INGESTION_PORT=3002
ANALYTICS_SERVICE_PORT=3003
RECOMMENDATION_SERVICE_PORT=3004
NOTIFICATION_SERVICE_PORT=3005
AI_ENGINE_PORT=5000
FRONTEND_PORT=3000

# Node
NODE_ENV=development
